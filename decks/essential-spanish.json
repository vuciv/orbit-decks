{
  "key": "essential-spanish",
  "version": 2,
  "name": "Essential Spanish",
  "description": "The highest-payoff Spanish vocabulary, trained in both directions: greetings and politeness words, numbers, days and months, time words, question words, pronouns, the 25 most useful verbs, family, food, places, core adjectives and colors, and the little connector words that glue sentences together. Latin American Spanish by default.",
  "category": "Language",
  "topics": [
    "spanish",
    "language",
    "vocabulary"
  ],
  "coverImage": "https://flagcdn.com/w640/es.png",
  "ttsLang": "es",
  "notes": [
    {
      "key": "hola",
      "model": "basic_reversed",
      "fields": {
        "front": "Hola",
        "back": "Hello",
        "extra": "Works in any situation, formal or informal, at any hour."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "buenos-dias",
      "model": "basic_reversed",
      "fields": {
        "front": "Buenos días",
        "back": "Good morning",
        "extra": "Used until about noon. Note the plural: buenos días."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "buenas-tardes",
      "model": "basic_reversed",
      "fields": {
        "front": "Buenas tardes",
        "back": "Good afternoon",
        "extra": "From noon until it gets dark."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "buenas-noches",
      "model": "basic_reversed",
      "fields": {
        "front": "Buenas noches",
        "back": "Good evening, good night",
        "extra": "Both a greeting and a farewell after dark."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "adios",
      "model": "basic_reversed",
      "fields": {
        "front": "Adiós",
        "back": "Goodbye",
        "extra": "Also common: hasta luego (see you later), hasta mañana (see you tomorrow), nos vemos (see you)."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "por-favor",
      "model": "basic_reversed",
      "fields": {
        "front": "Por favor",
        "back": "Please",
        "extra": "Attach it to any request: dos tacos, por favor."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "gracias",
      "model": "basic_reversed",
      "fields": {
        "front": "Gracias",
        "back": "Thank you",
        "extra": "Muchas gracias = thank you very much. The usual reply is de nada."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "de-nada",
      "model": "basic_reversed",
      "fields": {
        "front": "De nada",
        "back": "You're welcome",
        "extra": "Literally, it is nothing. Also common in Latin America: con gusto (with pleasure)."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "perdon",
      "model": "basic_reversed",
      "fields": {
        "front": "Perdón",
        "back": "Excuse me",
        "extra": "For getting attention, light apologies, or passing through a crowd. Disculpe is a slightly more formal alternative."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "lo-siento",
      "model": "basic_reversed",
      "fields": {
        "front": "Lo siento",
        "back": "I'm sorry",
        "extra": "For sympathy and real apologies; for small bumps and interruptions, perdón is enough."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
      "key": "mucho-gusto",
      "model": "basic_reversed",
      "fields": {
        "front": "Mucho gusto",
        "back": "Nice to meet you",
        "extra": "Said when meeting someone. The reply is igualmente (likewise)."
      },
      "tags": [
        "es::phrases"
      ]
    },
    {
