    },
    {
      "key": "digit-0",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 0 in radio voice procedure?",
        "back": "Zero",
        "extra": "Always Zero, never oh, which over the air can be mistaken for the letter O."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-1",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 1 in radio voice procedure?",
        "back": "Wun",
        "extra": "Written Wun in voice procedure guides to show that the final n must be sounded clearly."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-2",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 2 in radio voice procedure?",
        "back": "Too",
        "extra": "Written Too to show the long, stressed oo sound that carries over a noisy channel."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-3",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 3 in radio voice procedure?",
        "back": "Tree",
        "extra": "Tree replaces the th sound, which many non-native English speakers find difficult and which blurs over static."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-4",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 4 in radio voice procedure?",
        "back": "Fower",
        "extra": "Fower (rhymes with power) stretches four to two syllables so it is not heard as the word for."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-5",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 5 in radio voice procedure?",
        "back": "Fife",
        "extra": "Fife hardens the ending of five so it is not confused with fire over a weak signal."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-6",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 6 in radio voice procedure?",
        "back": "Six",
        "extra": "Six is already distinct from every other digit, so it is spoken normally."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-7",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 7 in radio voice procedure?",
        "back": "Seven",
        "extra": "Seven is spoken normally; its two syllables are rarely confused with any other digit."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-8",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 8 in radio voice procedure?",
        "back": "Ait",
        "extra": "Ait drops the soft gh ending of eight so the digit stays short and crisp over noise."
      },
      "tags": [
        "codes::nato-digits"
      ]
    },
    {
      "key": "digit-9",
      "model": "basic",
      "fields": {
        "front": "How do you say the digit 9 in radio voice procedure?",
        "back": "Niner",
        "extra": "Niner avoids confusion with the German nein and with five over static."
      },
      "tags": [
        "codes::nato-digits"
      ]
    }
  ]
