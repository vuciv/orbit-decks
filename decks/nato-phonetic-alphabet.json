{
  "key": "nato-phonetic-alphabet",
  "version": 1,
  "name": "NATO Phonetic Alphabet",
  "description": "The ICAO/NATO spelling alphabet from Alfa to Zulu, plus the ten digit pronunciations used in radio voice procedure, with official ICAO pronunciations.",
