    {
      "key": "a",
      "model": "typed",
      "fields": {
        "front": "NATO code word for the letter A?",
        "answer": "Alfa",
        "extra": "Pronounced AL-FAH. Commonly spelled Alpha, but the official ICAO spelling is Alfa, chosen deliberately so non-English speakers pronounce the f sound correctly."
      },
      "tags": [
        "codes::nato-letters"
      ]
    },
